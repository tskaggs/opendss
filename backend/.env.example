# Copy to `backend/.env` for local runs (never commit real secrets).
# Docker: pass `-e KEY=value` or use compose `environment:`.

# development | production (production disables /docs and OpenAPI JSON by default)
ENVIRONMENT=development

# Comma-separated browser origins for CORS (no spaces after commas)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Optional: allowed Host headers (e.g. api.example.com). Leave empty to disable.
TRUSTED_HOSTS=

# slowapi limit for POST /analyze (see slowapi format, e.g. 60/minute)
RATE_LIMIT_ANALYZE=60/minute

# When "true", rate limits use X-Forwarded-For (first hop). Only enable behind a trusted reverse proxy.
TRUST_FORWARDED_FOR=false
